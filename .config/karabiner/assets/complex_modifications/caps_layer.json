{
  "title": "Modular CapsLock System",
  "rules": [
    {
      "description": "CapsLock Base: Toggle Layer Variable (REQUIRED)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": { "optional": ["any"] }
          },
          "to": [
            { "set_variable": { "name": "caps_lock_pressed", "value": 1 } }
          ],
          "to_after_key_up": [
            { "set_variable": { "name": "caps_lock_pressed", "value": 0 } }
          ],
          "to_if_alone": [
            { "key_code": "caps_lock" }
          ]
        }
      ]
    },
    {
      "description": "CapsLock Nav: HJKL Arrow Keys",
      "manipulators": [
        { "type": "basic", "from": { "key_code": "h", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "left_arrow" }], "conditions": [{ "name": "caps_lock_pressed", "type": "variable_if", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "j", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "down_arrow" }], "conditions": [{ "name": "caps_lock_pressed", "type": "variable_if", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "k", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "up_arrow" }], "conditions": [{ "name": "caps_lock_pressed", "type": "variable_if", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "l", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "right_arrow" }], "conditions": [{ "name": "caps_lock_pressed", "type": "variable_if", "value": 1 }] }
      ]
    },
    {
      "description": "CapsLock Nav: I=Home, O=End",
      "manipulators": [
        { "type": "basic", "from": { "key_code": "i", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "left_arrow", "modifiers": ["left_command"] }], "conditions": [{ "name": "caps_lock_pressed", "type": "variable_if", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "o", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "right_arrow", "modifiers": ["left_command"] }], "conditions": [{ "name": "caps_lock_pressed", "type": "variable_if", "value": 1 }] }
      ]
    },
    {
      "description": "CapsLock Utils: Numbers to Function Keys",
      "manipulators": [
        { "type": "basic", "from": { "key_code": "1" }, "to": [{ "key_code": "f1", "modifiers": ["fn"] }], "conditions": [{ "name": "caps_lock_pressed", "type": "variable_if", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "2" }, "to": [{ "key_code": "f2", "modifiers": ["fn"] }], "conditions": [{ "name": "caps_lock_pressed", "type": "variable_if", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "3" }, "to": [{ "key_code": "f3", "modifiers": ["fn"] }], "conditions": [{ "name": "caps_lock_pressed", "type": "variable_if", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "4" }, "to": [{ "key_code": "f4", "modifiers": ["fn"] }], "conditions": [{ "name": "caps_lock_pressed", "type": "variable_if", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "5" }, "to": [{ "key_code": "f5", "modifiers": ["fn"] }], "conditions": [{ "name": "caps_lock_pressed", "type": "variable_if", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "6" }, "to": [{ "key_code": "f6", "modifiers": ["fn"] }], "conditions": [{ "name": "caps_lock_pressed", "type": "variable_if", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "7" }, "to": [{ "key_code": "f7", "modifiers": ["fn"] }], "conditions": [{ "name": "caps_lock_pressed", "type": "variable_if", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "8" }, "to": [{ "key_code": "f8", "modifiers": ["fn"] }], "conditions": [{ "name": "caps_lock_pressed", "type": "variable_if", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "9" }, "to": [{ "key_code": "f9", "modifiers": ["fn"] }], "conditions": [{ "name": "caps_lock_pressed", "type": "variable_if", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "0" }, "to": [{ "key_code": "f10", "modifiers": ["fn"] }], "conditions": [{ "name": "caps_lock_pressed", "type": "variable_if", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "hyphen" }, "to": [{ "key_code": "f11", "modifiers": ["fn"] }], "conditions": [{ "name": "caps_lock_pressed", "type": "variable_if", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "equal_sign" }, "to": [{ "key_code": "f12", "modifiers": ["fn"] }], "conditions": [{ "name": "caps_lock_pressed", "type": "variable_if", "value": 1 }] }
      ]
    },
    {
      "description": "CapsLock Utils: P to PrintScreen",
      "manipulators": [
        { "type": "basic", "from": { "key_code": "p", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "print_screen" }], "conditions": [{ "name": "caps_lock_pressed", "type": "variable_if", "value": 1 }] }
      ]
    }
  ]
}
